{
  "buildCommand": "cd ../.. && pnpm --filter @roadtrip/shared build && pnpm --filter @roadtrip/web build",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://roadtrip-planner-1s1t.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
